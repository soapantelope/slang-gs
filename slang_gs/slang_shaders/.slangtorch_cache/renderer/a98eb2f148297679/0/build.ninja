ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=_slangtorch_renderer_a98eb2f148297679_0 -DTORCH_API_INCLUDE_EXTENSION_H -I/viscam/u/sophiazh/slang-gs/slang_gs/slang_shaders -isystem /viscam/u/sophiazh/miniconda3/envs/slang/lib/python3.12/site-packages/torch/include -isystem /viscam/u/sophiazh/miniconda3/envs/slang/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /viscam/u/sophiazh/miniconda3/envs/slang/include/python3.12 -fPIC -std=c++17 -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=_slangtorch_renderer_a98eb2f148297679_0 -DTORCH_API_INCLUDE_EXTENSION_H -I/viscam/u/sophiazh/slang-gs/slang_gs/slang_shaders -isystem /viscam/u/sophiazh/miniconda3/envs/slang/lib/python3.12/site-packages/torch/include -isystem /viscam/u/sophiazh/miniconda3/envs/slang/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /viscam/u/sophiazh/miniconda3/envs/slang/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 --compiler-options '-fPIC' -std=c++17 --use_fast_math --generate-line-info -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -U__CUDA_NO_HALF2_OPERATORS__ -U__CUDA_NO_BFLOAT16_CONVERSIONS__ -DSLANG_CUDA_ENABLE_HALF=1
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/viscam/u/sophiazh/miniconda3/envs/slang/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build renderer.o: compile /viscam/u/sophiazh/slang-gs/slang_gs/slang_shaders/.slangtorch_cache/renderer/a98eb2f148297679/renderer.cpp
build renderer_cuda.cuda.o: cuda_compile /viscam/u/sophiazh/slang-gs/slang_gs/slang_shaders/.slangtorch_cache/renderer/a98eb2f148297679/renderer_cuda.cu





build _slangtorch_renderer_a98eb2f148297679_0.so: link renderer.o renderer_cuda.cuda.o

default _slangtorch_renderer_a98eb2f148297679_0.so
